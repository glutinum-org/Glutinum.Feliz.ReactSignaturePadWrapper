<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ManagePackageVersionsCentrally>False</ManagePackageVersionsCentrally>
        <!-- Disabled for __SOURCE_DIRECTORY__ to works on Github CI -->
        <ContinuousIntegrationBuild>false</ContinuousIntegrationBuild>
    </PropertyGroup>
    <ItemGroup>
        <Compile Include="Workspace.fs" />
        <Compile Include="Commands/Demo.fs" />
        <Compile Include="Commands/Publish.fs" />
        <Compile Include="Commands/Release.fs" />
        <Compile Include="Main.fs" />
    </ItemGroup>
    <ItemGroup>
      <PackageReference Include="BlackFox.CommandLine" Version="1.0.0" />
      <PackageReference Include="EasyBuild.FileSystemProvider" Version="1.1.0" />
      <PackageReference Include="EasyBuild.Tools" Version="7.0.0" />
      <PackageReference Include="FSharp.Core" Version="8.0.200" />
      <PackageReference Include="SimpleExec" Version="13.0.0" />
      <PackageReference Include="Spectre.Console.Cli" Version="0.48.0" />
    </ItemGroup>
</Project>
